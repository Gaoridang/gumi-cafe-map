# Gumi Cafe Map — Environment Variables
# Copy this file to .env (for local dev) and fill in your values.
# NEVER commit real secrets. .env is already gitignored.

# Kakao Maps JavaScript SDK key (required for the map to load)
# Get one at https://developers.kakao.com/ (JavaScript key)
# For local: usually works on http://localhost:5173
# For production (Vercel): set this exact var name in Vercel dashboard
#   (Project Settings → Environment Variables) for Production + Preview environments.
#   Then add the deployed domain(s) in the Kakao console under "Platform → Web".
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here
